---
const currentYear = new Date().getFullYear();
---

<footer class="topo-bg text-white/70">
  <!-- Stripe accent bar -->
  <div class="stripe-accent h-2"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <div class="flex items-center gap-3 mb-5">
          <img src="/images/logo.png" alt="Orlando Concrete Coating logo" class="w-10 h-10 object-contain" width="40" height="40" />
          <div class="leading-tight">
            <span class="block text-base font-heading font-bold text-white tracking-wide uppercase">Orlando</span>
            <span class="block text-[10px] font-heading text-accent tracking-[0.15em] uppercase">Concrete Coating</span>
          </div>
        </div>
        <p class="text-sm leading-relaxed mb-6">
          Central Florida's trusted concrete coating professionals. Transforming residential and commercial floors with premium epoxy, polyaspartic, and decorative coatings.
        </p>
        <div class="flex gap-3">
          <a href="#" class="w-9 h-9 bg-white/10 hover:bg-accent flex items-center justify-center transition-colors" aria-label="Facebook">
            <i class="fa-brands fa-facebook-f text-sm"></i>
          </a>
          <a href="#" class="w-9 h-9 bg-white/10 hover:bg-accent flex items-center justify-center transition-colors" aria-label="Instagram">
            <i class="fa-brands fa-instagram text-sm"></i>
          </a>
          <a href="#" class="w-9 h-9 bg-white/10 hover:bg-accent flex items-center justify-center transition-colors" aria-label="Google">
            <i class="fa-brands fa-google text-sm"></i>
          </a>
          <a href="#" class="w-9 h-9 bg-white/10 hover:bg-accent flex items-center justify-center transition-colors" aria-label="Yelp">
            <i class="fa-brands fa-yelp text-sm"></i>
          </a>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h3 class="font-heading font-bold text-white text-sm tracking-wider uppercase mb-5 flex items-center gap-2">
          <span class="w-6 h-0.5 bg-accent inline-block"></span>Services
        </h3>
        <ul class="space-y-3 text-sm">
          <li><a href="/services/epoxy-floor-coating" class="hover:text-accent transition-colors">Epoxy Floor Coatings</a></li>
          <li><a href="/services/polyaspartic-coating" class="hover:text-accent transition-colors">Polyaspartic Coatings</a></li>
          <li><a href="/services/decorative-concrete" class="hover:text-accent transition-colors">Decorative Concrete</a></li>
          <li><a href="/services/garage-floor-coating" class="hover:text-accent transition-colors">Garage Floor Coating</a></li>
          <li><a href="/services/pool-deck-resurfacing" class="hover:text-accent transition-colors">Pool Deck Resurfacing</a></li>
          <li><a href="/services/commercial-flooring" class="hover:text-accent transition-colors">Commercial Flooring</a></li>
          <li><a href="/services/commercial-pool-deck-surfacing" class="hover:text-accent transition-colors">Commercial Pool Decks</a></li>
        </ul>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="font-heading font-bold text-white text-sm tracking-wider uppercase mb-5 flex items-center gap-2">
          <span class="w-6 h-0.5 bg-accent inline-block"></span>Company
        </h3>
        <ul class="space-y-3 text-sm">
          <li><a href="/" class="hover:text-accent transition-colors">Home</a></li>
          <li><a href="/about" class="hover:text-accent transition-colors">About Us</a></li>
          <li><a href="/locations" class="hover:text-accent transition-colors">Service Areas</a></li>
          <li><a href="/contact" class="hover:text-accent transition-colors">Contact</a></li>
          <li><a href="/contact" class="hover:text-accent transition-colors">Free Estimates</a></li>
          <li><a href="/privacy-policy" class="hover:text-accent transition-colors">Privacy Policy</a></li>
          <li><a href="/terms-and-conditions" class="hover:text-accent transition-colors">Terms & Conditions</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-heading font-bold text-white text-sm tracking-wider uppercase mb-5 flex items-center gap-2">
          <span class="w-6 h-0.5 bg-accent inline-block"></span>Contact
        </h3>
        <ul class="space-y-4 text-sm">
          <li class="flex items-center gap-3">
            <i class="fa-solid fa-phone text-accent w-4 text-center"></i>
            <a href="tel:3218319421" class="hover:text-accent transition-colors">(321) 831-9421</a>
          </li>
          <li class="flex items-center gap-3">
            <i class="fa-solid fa-envelope text-accent w-4 text-center"></i>
            <a href="mailto:yeleussizovtamerlan@gmail.com" class="hover:text-accent transition-colors text-xs">yeleussizovtamerlan@gmail.com</a>
          </li>
          <li class="flex items-start gap-3">
            <i class="fa-solid fa-location-dot text-accent w-4 text-center mt-0.5"></i>
            <div>
              <span class="block">Serving Central Florida</span>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <i class="fa-solid fa-clock text-accent w-4 text-center mt-0.5"></i>
            <div>
              <span class="block">Open Daily: 8am - 8pm</span>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Service Areas -->
  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <h3 class="font-heading font-bold text-white text-sm tracking-wider uppercase mb-4 flex items-center gap-2">
        <span class="w-6 h-0.5 bg-accent inline-block"></span>Service Areas
      </h3>
      <div class="flex flex-wrap gap-x-4 gap-y-2 text-sm">
        <a href="/locations/orlando" class="hover:text-accent transition-colors">Orlando</a>
        <a href="/locations/winter-park" class="hover:text-accent transition-colors">Winter Park</a>
        <a href="/locations/kissimmee" class="hover:text-accent transition-colors">Kissimmee</a>
        <a href="/locations/lake-nona" class="hover:text-accent transition-colors">Lake Nona</a>
        <a href="/locations/dr-phillips" class="hover:text-accent transition-colors">Dr. Phillips</a>
        <a href="/locations/windermere" class="hover:text-accent transition-colors">Windermere</a>
        <a href="/locations/ocoee" class="hover:text-accent transition-colors">Ocoee</a>
        <a href="/locations/winter-garden" class="hover:text-accent transition-colors">Winter Garden</a>
        <a href="/locations/altamonte-springs" class="hover:text-accent transition-colors">Altamonte Springs</a>
        <a href="/locations/sanford" class="hover:text-accent transition-colors">Sanford</a>
        <a href="/locations/clermont" class="hover:text-accent transition-colors">Clermont</a>
        <a href="/locations/apopka" class="hover:text-accent transition-colors">Apopka</a>
      </div>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-white/40">
      <p>&copy; {currentYear} Orlando Concrete Coating. All rights reserved. Licensed &amp; Insured.</p>
      <p>Proudly serving Orlando, Winter Park, Kissimmee, Lake Nona &amp; Central Florida</p>
    </div>
  </div>
</footer>
